<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.control.ListView?>
<BorderPane styleClass="drop_course" prefHeight="800" HBox.hgrow="ALWAYS" fx:id="contentArea" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.pages.AddDropCoursesController" >
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets right="20.0" />
            </padding>
            <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdateCourses" text="Update" />
        </HBox>
    </top>
    <center>
    <ListView fx:id="coursesListView" BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
    </ListView>
    </center>
</BorderPane>