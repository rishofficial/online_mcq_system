<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/18"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo1.pages.Dashboard"
            prefHeight="720.0" prefWidth="1280.0"
            stylesheets="/com/example/demo1/styles.css">

    <!--left bar-->
    <left>
        <VBox alignment="TOP_CENTER"  spacing="15.0" styleClass="nav-rail">
            <padding>
                <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
            </padding>
            <fx:define>
                <ToggleGroup fx:id="navToggleGroup"/>
            </fx:define>
            <ToggleButton onAction="#showProfile" selected="true" styleClass="nav-button" text="🏠"
                          toggleGroup="$navToggleGroup">
                <tooltip>
                    <Tooltip text="Home/Profile"/>
                </tooltip>
            </ToggleButton>

            <ToggleButton onAction="#showChats" styleClass="nav-button" text="💬" toggleGroup="$navToggleGroup">
                <tooltip>
                    <Tooltip text="Chats"/>
                </tooltip>
            </ToggleButton>

            <ToggleButton onAction="#showTeams" styleClass="nav-button" text="👥" toggleGroup="$navToggleGroup">
                <tooltip>
                    <Tooltip text="Teams"/>
                </tooltip>
            </ToggleButton>

            <Pane VBox.vgrow="ALWAYS"/>
            <Button onAction="#logout" styleClass="nav-button" text="🚪" >
            <tooltip>
                <Tooltip text="Logout"/>
            </tooltip>
        </Button>
        </VBox>
    </left>

    <center>
        <AnchorPane prefHeight="720.0" prefWidth="400.0" BorderPane.alignment="CENTER" />
        <VBox prefWidth="400.0" styleClass="list-pane">
            <padding>
                <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
            </padding>
            <TextField fx:id="SearchField" onAction="#searchUser" promptText="Search" styleClass="nav-search-field" minWidth="350"/>
            <Label styleClass="list-pane-title" text="All Chats"/>
            <ListView fx:id="sideListView" VBox.vgrow="ALWAYS" styleClass="chat-list-view"/>
        </VBox>
    </center>

    <!--right content area-->
    <right>
        <AnchorPane fx:id="contentArea" prefHeight="720.0" prefWidth="800.0" BorderPane.alignment="CENTER" />
    </right>

</BorderPane>