<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="contentArea" prefHeight="400.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo1.pages.ProfileController">
    <VBox layoutX="30.0" layoutY="30.0" spacing="15.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
        <Label styleClass="header-label" text="User Profile" />
        <GridPane hgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="183.4" minWidth="10.0" prefWidth="150.4" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="529.0" minWidth="10.0" prefWidth="529.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <Label styleClass="info-title-label" text="Name:" />
            <Label styleClass="info-title-label" text="Age:" GridPane.rowIndex="1" />
            <Label styleClass="info-title-label" text="User ID:" GridPane.rowIndex="2" />
            <Label styleClass="info-title-label" text="Role:" GridPane.rowIndex="3" />
            <Label fx:id="nameLabel" styleClass="info-data-label" text="[Name]" GridPane.columnIndex="1" />
            <Label fx:id="ageLabel" styleClass="info-data-label" text="[Age]" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="userIdLabel" styleClass="info-data-label" text="[UserID]" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="roleLabel" styleClass="info-data-label" text="[Role]" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>
        <Separator />
        <GridPane fx:id="enrolledCoursesGridPane" hgap="10" styleClass="courses-grid" vgap="15">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="300.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" />
            </rowConstraints>
            <Label styleClass="course-title-label" text="Enrolled Courses:" />
        </GridPane>
        <Button mnemonicParsing="false" onAction="#handleAddDropCourses" styleClass="button_profile" text="Add/Drop Courses" />
        <Separator />
    </VBox>
</AnchorPane>
